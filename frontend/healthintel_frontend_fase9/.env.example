# URL pública da sua FastAPI.
VITE_API_BASE_URL=http://localhost:8080

# Em homologação local, falhas da API devem aparecer como erro real.
VITE_ENABLE_DEMO_FALLBACK=false

# Nome comercial exibido no portal.
VITE_APP_NAME=HealthIntel Core ANS

# Google OAuth Client ID (Google Cloud Console → APIs & Services → Credentials).
# Deixar vazio desativa o botão "Entrar com Google".
VITE_GOOGLE_CLIENT_ID=
