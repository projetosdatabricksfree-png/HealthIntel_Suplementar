FROM node:22-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .
ARG VITE_API_BASE_URL
ARG VITE_GOOGLE_CLIENT_ID
ARG VITE_STRIPE_PAYMENT_LINK_SANDBOX
ARG VITE_STRIPE_PAYMENT_LINK_PILOTO
ARG VITE_STRIPE_PAYMENT_LINK_CORE_API
ARG VITE_STRIPE_PAYMENT_LINK_CORE_PRO
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_GOOGLE_CLIENT_ID=$VITE_GOOGLE_CLIENT_ID
ENV VITE_STRIPE_PAYMENT_LINK_SANDBOX=$VITE_STRIPE_PAYMENT_LINK_SANDBOX
ENV VITE_STRIPE_PAYMENT_LINK_PILOTO=$VITE_STRIPE_PAYMENT_LINK_PILOTO
ENV VITE_STRIPE_PAYMENT_LINK_CORE_API=$VITE_STRIPE_PAYMENT_LINK_CORE_API
ENV VITE_STRIPE_PAYMENT_LINK_CORE_PRO=$VITE_STRIPE_PAYMENT_LINK_CORE_PRO
RUN npm run build

FROM nginx:1.27-alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
