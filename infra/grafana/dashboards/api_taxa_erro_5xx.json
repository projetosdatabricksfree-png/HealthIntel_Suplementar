{
  "uid": "hi-api-erros-5xx",
  "title": "API — Taxa de Erro 5xx",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-3h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Taxa de erro 5xx por endpoint (req/s)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 8},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 0.01}
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{job=\"healthintel_api\",status_code=~\"5..\"}[5m])) by (handler)",
          "legendFormat": "5xx {{handler}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total 5xx (última hora)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 8, "w": 8, "h": 4},
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 10}
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(http_requests_total{job=\"healthintel_api\",status_code=~\"5..\"}[1h]))",
          "legendFormat": "5xx total"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Taxa de erro geral (%)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 8, "y": 8, "w": 8, "h": 4},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(rate(http_requests_total{job=\"healthintel_api\",status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"healthintel_api\"}[5m]))",
          "legendFormat": "% erro"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Throughput total por status code (req/s)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 12, "w": 24, "h": 8},
      "fieldConfig": {
        "defaults": {"unit": "reqps"}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{job=\"healthintel_api\"}[5m])) by (status_code)",
          "legendFormat": "{{status_code}}"
        }
      ]
    }
  ]
}
