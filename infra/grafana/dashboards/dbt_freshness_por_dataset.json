{
  "uid": "hi-dbt-freshness",
  "title": "DBT — Freshness por Dataset",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5m",
  "time": {"from": "now-24h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Última carga bem-sucedida por dataset",
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgres"},
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 12},
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "horas_atras"},
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "green", "value": null},
                    {"color": "yellow", "value": 25},
                    {"color": "red", "value": 49}
                  ]
                }
              },
              {"id": "custom.displayMode", "value": "color-background"}
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT\n  fonte_ans AS dataset,\n  MAX(finalizado_em) AS ultima_carga,\n  ROUND(EXTRACT(EPOCH FROM (NOW() - MAX(finalizado_em)))/3600, 1) AS horas_atras\nFROM plataforma.job\nWHERE status = 'sucesso'\n  AND fonte_ans IS NOT NULL\nGROUP BY 1\nORDER BY 3 ASC",
          "format": "table"
        }
      ]
    },
    {
      "id": 2,
      "type": "table",
      "title": "Jobs com erro nas últimas 24h",
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgres"},
      "gridPos": {"x": 0, "y": 12, "w": 24, "h": 8},
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT\n  dag_id,\n  nome_job,\n  fonte_ans,\n  status,\n  iniciado_em,\n  LEFT(mensagem_erro, 120) AS erro\nFROM plataforma.job\nWHERE status IN ('erro', 'falha')\n  AND iniciado_em > NOW() - INTERVAL '24 hours'\nORDER BY iniciado_em DESC\nLIMIT 20",
          "format": "table"
        }
      ]
    }
  ]
}
