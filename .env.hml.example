# HealthIntel Core ANS - homologacao por dominio HTTPS.
# Copiar para .env.hml na VPS e trocar todos os placeholders.
# Nunca preencher segredos reais neste arquivo versionado.

APP_ENV=hml
API_ENV=hml
LAYOUT_SERVICE_ENV=hml

FRONTEND_PUBLIC_URL=https://app.healthintel.com.br
API_PUBLIC_URL=https://api.healthintel.com.br

POSTGRES_DB=healthintel
POSTGRES_USER=healthintel
POSTGRES_PASSWORD=<trocar>
POSTGRES_EXTERNAL_PORT=127.0.0.1:5432

MONGO_DB=healthintel_layout
MONGO_INITDB_ROOT_USERNAME=healthintel
MONGO_INITDB_ROOT_PASSWORD=<trocar>
MONGO_EXTERNAL_PORT=127.0.0.1:27018

REDIS_EXTERNAL_PORT=127.0.0.1:6379

API_EXTERNAL_PORT=127.0.0.1:8080
FRONTEND_EXTERNAL_PORT=127.0.0.1:3000
LAYOUT_EXTERNAL_PORT=127.0.0.1:8081

API_PREFIX=/v1
API_RATE_LIMIT_RPM=60
API_RATE_LIMIT_FAIL_OPEN=false
API_ALLOWED_HOSTS=localhost,127.0.0.1,5.189.160.27,app.healthintel.com.br,api.healthintel.com.br,api,healthintel_api
API_CORS_ALLOWED_ORIGINS=https://app.healthintel.com.br,https://api.healthintel.com.br,http://app.healthintel.com.br,http://api.healthintel.com.br:8080,http://5.189.160.27,http://5.189.160.27:8080,http://localhost:5173,http://127.0.0.1:5173
API_MAX_REQUEST_SIZE_BYTES=1048576
API_JWT_ADMIN_SECRET=<trocar>

LAYOUT_SERVICE_TOKEN=<trocar>
LAYOUT_SERVICE_ALLOWED_HOSTS=localhost,127.0.0.1,mongo_layout_service,healthintel_layout_service
LAYOUT_SERVICE_MAX_REQUEST_SIZE_BYTES=1048576

VITE_API_BASE_URL=https://api.healthintel.com.br
VITE_ENABLE_DEMO_FALLBACK=false
VITE_APP_NAME=HealthIntel Core ANS

# Usadas apenas pelos scripts de healthcheck. Trocar se a seed da VPS usar outras chaves.
HML_DEV_API_KEY=hi_local_dev_2026_api_key
HML_ADMIN_API_KEY=hi_local_admin_2026_api_key

# Variaveis mantidas para compatibilidade com infra/docker-compose.hml.yml.
# O deploy inicial por IP NAO sobe Airflow nem dbt.
AIRFLOW_EXTERNAL_PORT=127.0.0.1:8088
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW_FERNET_KEY=<trocar_se_airflow_for_usado>
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=<trocar_se_airflow_for_usado>
AIRFLOW_ADMIN_EMAIL=admin@healthintel.local

ANS_ANOS_CARGA_HOT=2
LOG_LEVEL=INFO

# pgBackRest repo2 (S3-compatible) — Sprint 40 / §18.2
# Nao preencher aqui. Guardar em /etc/healthintel/pgbackrest.env (chmod 600) na VPS.
# Para ativar: set -a; source /etc/healthintel/pgbackrest.env; set +a
# Depois: bash scripts/vps/setup_pgbackrest_repo2.sh
#
# Provedor recomendado MVP: Cloudflare R2 (egress gratuito, S3-compatible)
#   PGBACKREST_REPO2_ENDPOINT  = <account_id>.r2.cloudflarestorage.com
#   PGBACKREST_REPO2_REGION    = auto
#
# Para AWS S3:
#   PGBACKREST_REPO2_ENDPOINT  = s3.us-east-1.amazonaws.com
#   PGBACKREST_REPO2_REGION    = us-east-1
#
PGBACKREST_REPO2_ENDPOINT=<trocar_endpoint_s3>
PGBACKREST_REPO2_BUCKET=<trocar_nome_bucket>
PGBACKREST_REPO2_REGION=<trocar_regiao>
PGBACKREST_REPO2_KEY=<trocar_access_key_id>
PGBACKREST_REPO2_KEY_SECRET=<trocar_secret_access_key>
PGBACKREST_REPO2_CIPHER_PASS=<trocar_min_32_chars_aleatorios>
POSTGRES_DATA_DIR=/var/lib/postgresql/16/main

# Sentry (§19.2) — DSN do projeto na conta Sentry.io
SENTRY_DSN=<trocar_se_sentry_for_usado>
